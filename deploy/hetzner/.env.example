# Hetzner production environment.
# Copy to `.env` and fill all values. Never commit .env to git.

# ─── Postgres (used by db service AND constructs DATABASE_URL for api) ──
POSTGRES_DB=jones
POSTGRES_USER=django
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=

# ─── Django ──
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=

# Reuse value from current Cloud Run env. Read it with:
#   gcloud run services describe jones-api \
#     --project=jones --region=asia-southeast1 \
#     --format='value(spec.template.spec.containers[0].env[?(@.name=="ADMIN_API_KEY")].value)'
ADMIN_API_KEY=

# Public site URLs
SITE_URL=https://www.jones.com
CSRF_TRUSTED_ORIGINS=https://jones.com,https://www.jones.com,https://api.jones.com
CORS_ALLOWED_ORIGINS=https://jones.com,https://www.jones.com

# ─── Media storage ──
# Media files (product images, uploads) are stored on the local host
# at ./media-bucket/ which is bind-mounted into both the api and nginx
# containers. No GCS or other cloud dependency.
#
# Backup: include ./media-bucket/ in the daily Hetzner snapshot (already
# enabled at the server level) and the weekly off-site dump.

# ─── SSL ──
LETSENCRYPT_EMAIL=hai.pham@genesisda.com

# ─── WP/.shop review sync (WooCommerce REST API) ──
# Dùng cho:
#   - python manage.py sync_shop_reviews   (one-shot importer .shop → .com)
#   - Forward push khi user submit review trên .com (auto)
# Tạo cặp ck_/cs_ tại: WP Admin → WooCommerce → Settings → Advanced → REST API.
# Permissions cần: Read/Write (vì cần POST review mới lên .shop).
WP_SHOP_BASE_URL=https://jones.shop
WP_SHOP_WC_CONSUMER_KEY=
WP_SHOP_WC_CONSUMER_SECRET=
